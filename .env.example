# =============================================================================
# DeepBook Predict — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's already in .gitignore).

# --- Required: Sui Wallet ---
PRIVATE_KEY=                  # Your Sui private key (hex, without 0x prefix)

# --- Required: Deployed Package IDs ---
PACKAGE_ID=                   # Predict package ID (0x...)
PREDICT_ID=                   # Predict shared object ID
REGISTRY_ID=                  # Oracle registry object ID
MANAGER_ID=                   # Balance manager object ID

# --- Required: Oracle Object IDs ---
ADMIN_CAP_ID=                 # Admin capability object ID
ORACLE_CAP_ID=                # Oracle capability object ID
BTC_ORACLE_ID=                # BTC oracle object ID
ETH_ORACLE_ID=                # ETH oracle object ID (optional)
DEEP_ORACLE_ID=               # DEEP oracle object ID (optional)

# --- Required: Token Types ---
DEEP_TYPE=                    # DEEP coin type (0x...::deep::DEEP)
DUSDC_TYPE=                   # dUSDC coin type (0x...::dusdc::DUSDC)

# --- Network ---
NETWORK=testnet                # testnet | mainnet

# --- Trading Config ---
TRADING_ENABLED=true          # Enable/disable trading
ORACLE_DURATION_MS=28800000   # Oracle duration (8 hours)
ADMIN_ADDRESS=                # Admin wallet address

# --- Market Strike/Tick Config ---
BTC_MIN_STRIKE=60000000000000
BTC_TICK_SIZE=1000000000000
ETH_MIN_STRIKE=1000000000000
ETH_TICK_SIZE=50000000000
DEEP_MIN_STRIKE=5000000
DEEP_TICK_SIZE=1000000

# --- Telegram Alerts (optional) ---
TELEGRAM_BOT_TOKEN=           # Telegram bot token from @BotFather
TELEGRAM_CHAT_ID=             # Your Telegram chat ID
